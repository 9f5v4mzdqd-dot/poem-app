<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>詩をつくろう</title>

<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@300;400;500&family=Shippori+Mincho:wght@400;500;600&display=swap" rel="stylesheet">

<style>
* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: 'Noto Serif JP', serif;
  background: #1a1a2e;
}

/* 🌌 空 */
.sky-section {
  position: relative;
  overflow: hidden;
  padding-bottom: 100px;
  background: linear-gradient(
    to bottom,
    #1c2a4a 0%, #2d3f6b 40%, #7a7aaa 70%, #e8d0a0 100%
  );
}

/* ⭐ 星空（復活ポイント） */
.sky-section::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image:
    radial-gradient(1px 1px at 15% 12%, rgba(255,255,255,0.9), transparent),
    radial-gradient(1.5px 1.5px at 32% 8%, rgba(255,255,255,0.8), transparent),
    radial-gradient(1px 1px at 48% 15%, rgba(255,255,255,0.7), transparent),
    radial-gradient(1px 1px at 65% 6%, rgba(255,255,255,0.9), transparent),
    radial-gradient(1.5px 1.5px at 78% 18%, rgba(255,255,255,0.6), transparent);
  pointer-events: none;
}

/* ボタン固定 */
.gen-wrap {
  position: fixed;
  bottom: 20px;
  left: 0;
  width: 100%;
  padding: 0 18px;
  z-index: 100;
}

.gen-btn {
  width: 100%;
  padding: 14px;
  border-radius: 30px;
  border: none;
  background: #5a8a7a;
  color: #fff;
  font-size: 1rem;
}

/* テキスト */
h2 {
  text-align: center;
  color: white;
  padding: 20px;
}

/* カード */
.word-card, .conj-chip {
  margin: 5px;
  padding: 8px 12px;
  cursor: pointer;
  border-radius: 6px;
  border: none;
}

.word-card {
  background: #fff;
}

.conj-chip {
  background: #ffe4b5;
}

.word-card.selected,
.conj-chip.selected {
  background: #4a6a9a;
  color: #fff;
}

/* プレビュー */
.preview-panel {
  background: #f7f4f0;
  padding-bottom: 100px;
}

.poem-display {
  padding: 20px;
  text-align: center;
}

.poem-line {
  font-size: 1.3rem;
  margin-bottom: 10px;
}
</style>
</head>

<body>

<div class="sky-section">
  <h2>詩をつくろう</h2>
  <div id="posBlocks" style="padding:10px;"></div>

  <div class="gen-wrap">
    <button class="gen-btn" onclick="generatePoem()">詩に追加する</button>
  </div>
</div>

<div class="preview-panel">
  <div class="poem-display" id="poemDisplay">
    <div>ことばを選んで詩をつくってください</div>
  </div>
</div>

<script>
const words = {
  noun: ["月","影","風","花"],
  verb: ["揺れる","漂う","消える"],
  adj: ["儚い","冷たい","優しい"],
  adv: ["そっと","ゆっくり"],
  conj: ["の","と"]
};

let selected = {};
let poemStack = [];

function renderCards() {
  const container = document.getElementById("posBlocks");
  container.innerHTML = "";

  Object.keys(words).forEach(pos => {
    const div = document.createElement("div");
    div.innerHTML = "<h4 style='color:white'>" + pos + "</h4>";

    words[pos].forEach(w => {
      const btn = document.createElement("button");
      btn.textContent = w;
      btn.className = pos === "conj" ? "conj-chip" : "word-card";

      btn.onclick = () => {
        selected[pos] = w;
        document.querySelectorAll("." + btn.className).forEach(b => b.classList.remove("selected"));
        btn.classList.add("selected");
      };

      div.appendChild(btn);
    });

    container.appendChild(div);
  });
}

function generatePoem() {
  let line = "";

  if (selected.adj && selected.noun) {
    line += selected.adj + (selected.conj || "") + selected.noun;
  } else if (selected.noun) {
    line += selected.noun;
  }

  if (selected.adv && selected.verb) {
    line += "\n" + selected.adv + "、" + selected.verb;
  }

  if (!line) return;

  poemStack.push(line);
  renderPoem();
}

function renderPoem() {
  const display = document.getElementById("poemDisplay");
  display.innerHTML = "";

  poemStack.forEach(line => {
    const div = document.createElement("div");
    div.className = "poem-line";
    div.textContent = line;
    display.appendChild(div);
  });
}

renderCards();
</script>

</body>
</html>